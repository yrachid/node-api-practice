{
  "name": "api-practice",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx app/src/index.ts | jq -R '. as $line | try(fromjson) catch $line'",
    "test": "NODE_ENV=test vitest run --no-file-parallelism",
    "migrate:add": "bash ./scripts/new-migration.sh",
    "migrate:up": "tsx app/src/migrate.ts | jq -R '. as $line | try(fromjson) catch $line'",
    "migrate:down": "tsx app/src/migrate.ts down | jq -R '. as $line | try(fromjson) catch $line'"
  },
  "dependencies": {
    "cache-manager": "^7.2.8",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "kysely": "^0.28.12",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
